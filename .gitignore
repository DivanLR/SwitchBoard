# Only the installer is attached to a GitHub release; nothing goes in git.
*.exe
*.blockmap
latest*.yml
*.nupkg

# --- Secrets / signing material (never commit) ---
*.pem
*.key
*.p12
*.pfx
*.local
npm-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Test and coverage artifacts (temporary) ---
coverage/
test-results/
playwright-report/

# --- Logs and environment ---
*.log
.env
.env.*

# --- OS and editor cruft ---
.DS_Store
Thumbs.db
*.tmp
*.swp
