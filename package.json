{
  "name": "terminal-switchboard",
  "version": "0.2.0",
  "description": "Switchboard: one desktop window hosting every Claude Code session, with a central permission inbox, clean output views, and per-project context.",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "npm run rebuild:electron && electron-vite dev",
    "dev:renderer": "vite --config vite.config.ts",
    "build": "electron-vite build",
    "package": "npm run rebuild:electron && npm run build && electron-builder --win",
    "package:portable": "npm run rebuild:electron && npm run build && electron-builder --win portable",
    "lint": "eslint .",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json",
    "test": "npm run rebuild:node && vitest run",
    "test:e2e": "playwright test",
    "prune": "npm run rebuild:node && tsx src/main/store/prune-cli.ts",
    "rebuild:electron": "node scripts/swap-sqlite.mjs electron",
    "rebuild:node": "node scripts/swap-sqlite.mjs node"
  },
  "author": "Haefele Software",
  "license": "UNLICENSED",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.215",
    "better-sqlite3": "^12.11.1",
    "electron-updater": "^6.8.9",
    "pinia": "^4.0.2",
    "vue": "^3.5.40"
  },
  "devDependencies": {
    "@electron/fuses": "^2.1.3",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.1",
    "@vitejs/plugin-vue": "^6.0.8",
    "electron": "^42.7.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.2",
    "prebuild-install": "^7.1.3",
    "prettier": "^3.9.5",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^7.3.6",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.7"
  }
}
